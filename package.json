{
  "name": "vibeperks-vscode",
  "displayName": "VibePerks",
  "version": "0.1.0",
  "description": "VibePerks sponsor unit for the Claude Code and Codex VS Code panels - one quiet sponsor line in the agent spinner that earns you credit while your agent works.",
  "publisher": "vibeperks",
  "license": "PolyForm-Shield-1.0.0",
  "homepage": "https://vibeperks.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/VibePerks/vscode.git"
  },
  "type": "commonjs",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "vibeperks",
    "claude-code",
    "codex",
    "sponsor"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vibeperks.signIn",
        "title": "VibePerks: Sign in"
      },
      {
        "command": "vibeperks.signOut",
        "title": "VibePerks: Sign out"
      },
      {
        "command": "vibeperks.restoreClaudeCode",
        "title": "VibePerks: Restore Claude Code"
      },
      {
        "command": "vibeperks.restoreCodex",
        "title": "VibePerks: Restore Codex"
      },
      {
        "command": "vibeperks.restoreAll",
        "title": "VibePerks: Restore all patched panels"
      },
      {
        "command": "vibeperks.diagnose",
        "title": "VibePerks: Diagnose"
      },
      {
        "command": "vibeperks.menu",
        "title": "VibePerks: Open menu"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "format:check": "prettier --check \"src/**/*.{ts,js}\" \"tests/**/*.ts\"",
    "package": "npm run build && vsce package --no-dependencies -o vibeperks.vsix"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
